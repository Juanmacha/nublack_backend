# Database
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=3306

# Auth
JWT_SECRET=

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173

# Email (Gmail)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="NUBLACK Store" <noreply@example.com>
# Correos admin (separados por coma). También se usan usuarios con rol administrador en BD.
ADMIN_EMAIL=admin@nublack12.com

# Wompi - Developers (sandbox)
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxx
WOMPI_ENV=sandbox
WOMPI_REDIRECT_URL=https://nublack12.com/pago/resultado
FRONTEND_URL=https://nublack12.com
# Sandbox: localhost en redirect causa 403 en Wompi. Si desarrollas en local, usa tu dominio HTTPS:
# WOMPI_SANDBOX_REDIRECT_URL=https://nublack12.com/pago/resultado
PAYMENT_EXPIRY_MINUTES=40
# WOMPI_DEBUG=true
